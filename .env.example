# --- Required ---

# Your Neon (or any Postgres) connection string
DATABASE_URL="postgres://user:password@host/dbname?sslmode=require"

# The password YOU use to log into the dashboard (pick anything)
APP_PASSWORD="pick-a-secret-password"

# Google OAuth credentials (see README → "Google setup")
GOOGLE_CLIENT_ID="xxxxxxxx.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-xxxxxxxx"

# --- Optional ---

# Where the app lives. Use http://localhost:3000 locally,
# and your real URL (e.g. https://bookme-xxx.vercel.app) in production.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Separate secret for signing login cookies (falls back to APP_PASSWORD)
# SESSION_SECRET="another-random-string"
