# --- Database (Neon) ---
DATABASE_URL="postgres://user:password@host/dbname?sslmode=require"

# --- Neon Auth (user sign-in) ---
# From your Neon project → Auth tab
NEON_AUTH_BASE_URL="https://your-project.neonauth.us-east-1.aws.neon.tech/neondb"
# Any 32+ char random string: openssl rand -base64 32
NEON_AUTH_COOKIE_SECRET="generate-a-long-random-string-here"

# --- Google OAuth (calendar connections) ---
GOOGLE_CLIENT_ID="xxxxxxxx.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-xxxxxxxx"

# --- App URL ---
# http://localhost:3000 locally; your real URL in production
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Optional: smarter to-do extraction from meeting notes ---
# When set, Claude turns Granola meeting notes into clean action items.
# Without it, a simpler built-in parser is used.
# ANTHROPIC_API_KEY="sk-ant-..."
